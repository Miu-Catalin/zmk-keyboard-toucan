#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define BASE 0
#define NAV  1
#define SYM  2
#define ADJ  3

/ {
    behaviors {
        td_esc_caps: tap_dance_esc_caps {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp ESC>, <&kp CAPS>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";
        tri_layer {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base {
            display-name = "BASE";
            bindings = <
                &td_esc_caps    &kp Q         &kp W         &lt NAV E     &kp R         &kp T         &kp Y         &kp U         &kp I         &kp O         &kp P          &kp BSPC
                &mt LSHFT TAB   &mt LCTRL A   &mt LGUI S    &mt LALT D    &kp F         &kp G         &kp H         &kp J         &mt RALT K    &mt RGUI L    &mt RCTRL SEMI &mt RSHFT SQT
                &kp LSHFT       &kp Z         &kp X         &kp C         &kp V         &kp B         &kp N         &kp M         &kp COMMA     &kp DOT       &kp FSLH       &kp RSHFT
                                                            &mo NAV       &kp BSPC      &kp DEL       &kp RET       &kp SPACE     &mo SYM
            >;
        };

        nav {
            display-name = "NAV";
            bindings = <
                &trans      &kp N1          &kp N2       &kp N3       &kp N4       &kp N5         &trans   &kp HOME &kp PG_UP &kp PG_DN &kp END   &trans
                &bt BT_CLR  &bt BT_SEL 0    &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4   &trans   &kp LEFT &kp DOWN  &kp UP    &kp RIGHT &trans
                &trans      &studio_unlock  &trans       &trans       &trans       &trans         &trans   &trans   &trans    &trans    &trans    &trans
                                                            &trans        &trans       &trans         &trans   &trans    &trans
            >;
        };

        sym {
            display-name = "SYM";
            bindings = <
                &trans   &kp EXCL &kp AT   &kp LBRC &kp RBRC &kp PIPE    &kp UP   &kp N7 &kp N8 &kp N9 &kp STAR &kp BSPC
                &trans   &kp HASH &kp DLLR &kp LPAR &kp RPAR &kp GRAVE   &kp DOWN &kp N4 &kp N5 &kp N6 &kp PLUS &trans
                &trans   &kp PRCNT &kp CARET &kp LBKT &kp RBKT &kp TILDE   &kp AMPS &kp N1 &kp N2 &kp N3 &kp BSLH &trans
                                           &trans   &trans   &trans      &trans   &trans &trans
            >;
        };

        adj {
            display-name = "ADJ";
            bindings = <
                &mo TAB   &trans &kp F7 &kp F8 &kp F9 &kp F12   &kp C_VOL_DN &kp C_MUTE  &kp C_VOL_UP &trans &trans &kp BSPC
                &kp LCTRL &trans &kp F4 &kp F5 &kp F6 &kp F11   &trans       &trans      &trans       &trans &trans &trans
                &bt LSHFT &trans &kp F1 &kp F2 &kp F3 &kp F10   &trans       &trans      &trans       &trans &trans &trans
                                   &trans &trans &trans         &trans &trans &trans
            >;
        };
        extra_1 {
                status = "reserved";
        };

        extra_2 {
                status = "reserved";
        };

        extra_3 {
                status = "reserved";
        };
    };
};
